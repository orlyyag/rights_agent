# Gemini — paid tier so the index build + RAGAS eval aren't throttled (§0 Grill Q9)
GEMINI_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Access control (§0 #5): space/comma-separated chat ids from @userinfobot
ALLOWED_CHAT_IDS=

# Observability — LangSmith tracing (A8). Set the key and every embed/generate
# (and Tier-1 agent-graph nodes) shows up at smith.langchain.com.
LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=kolzchut-bot

# Crawler etiquette (PLAN §5.3): contact email included in the MediaWiki
# User-Agent so the wiki operators can reach you about crawl behavior.
KZ_CONTACT_EMAIL=

# Eval judge (cross-provider, EVAL-ONLY — the bot itself never calls OpenAI).
# Generator is Gemini; judge is OpenAI so it has no self-preference.
OPENAI_API_KEY=
# OPENAI_JUDGE_MODEL=gpt-4.1
# OPENAI_JUDGE_REASONING_EFFORT=low

# ── Optional overrides (defaults live in config.py) ──
# KZ_GEN_MODEL=gemini-3.5-flash
# KZ_ANSWER_LANGUAGE_MODE=auto # auto | he_ru; auto answers non-he/ru questions in their main language
# KZ_SIM_FLOOR=0.35           # lenient pre-filter; calibrate per-lang (T12)
# KZ_RATE_LIMIT_PER_MIN=20
# KZ_DAILY_QUESTION_CAP=20    # per-chat answered-questions/day budget cap; 0 = unlimited
# KZ_GLOBAL_RATE_PER_MIN=60   # system-wide answers/min across all chats (botnet backstop); 0 = unlimited
# KZ_GLOBAL_DAILY_CAP=1000    # system-wide answers/day across all chats; 0 = unlimited
# KZ_BOT_WORKERS=32           # answer threads; sized for ~20 parallel users
# KZ_BOT_MAX_INFLIGHT=64      # load-shed ceiling (running+queued) before a "busy" reply; 0 = off
# KZ_DATA_DIR=./data
