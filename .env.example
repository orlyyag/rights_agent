# Gemini — paid tier so the index build + RAGAS eval aren't throttled (§0 Grill Q9)
GEMINI_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Access control (§0 #5): space/comma-separated chat ids from @userinfobot
ALLOWED_CHAT_IDS=

# ── Optional overrides (defaults live in config.py) ──
# KZ_GEN_MODEL=gemini-3-flash
# KZ_SOURCE=corpus            # corpus | pipeline
# KZ_SIM_FLOOR=0.35           # lenient pre-filter; calibrate per-lang (T12)
# KZ_RATE_LIMIT_PER_MIN=20
# KZ_DATA_DIR=./data
