# Gemini — paid tier so the index build + RAGAS eval aren't throttled (§0 Grill Q9)
GEMINI_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Access control (§0 #5): space/comma-separated chat ids from @userinfobot
ALLOWED_CHAT_IDS=

# Observability — LangSmith tracing (A8). Set the key and every embed/generate
# (and Tier-1 agent-graph nodes) shows up at smith.langchain.com.
LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=kolzchut-bot

# Eval judge (cross-provider, EVAL-ONLY — the bot itself never calls OpenAI).
# Generator is Gemini; judge is OpenAI so it has no self-preference.
OPENAI_API_KEY=
# OPENAI_JUDGE_MODEL=o4-mini
# OPENAI_JUDGE_REASONING_EFFORT=low

# ── Optional overrides (defaults live in config.py) ──
# KZ_GEN_MODEL=gemini-3.5-flash
# KZ_SOURCE=corpus            # corpus | pipeline
# KZ_SIM_FLOOR=0.35           # lenient pre-filter; calibrate per-lang (T12)
# KZ_RATE_LIMIT_PER_MIN=20
# KZ_DATA_DIR=./data
